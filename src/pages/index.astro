---
import Layout from '../layouts/Layout.astro';
import { Starfield } from '../components/SpaceJourney/Starfield';
import { MeteoriteField } from '../components/SpaceJourney/MeteoriteField';
import { CockpitHUD } from '../components/SpaceJourney/CockpitHUD';
import { WhoAmI } from '../components/SpaceJourney/WhoAmI';
import { PlanetScene } from '../components/SpaceJourney/PlanetScene';
import { DeveloperCredit } from '../components/SpaceJourney/DeveloperCredit';
import { ScrollSnapController } from '../components/SpaceJourney/ScrollSnapController';
import { JumpHandler } from '../components/SpaceJourney/JumpHandler';
import { SwipeIndicator } from '../components/SpaceJourney/SwipeIndicator';
import { SocialLinks } from '../components/SpaceJourney/SocialLinks';

const experiences = [
  { order: 1, title: "Marketing Executive Trainee", company: "SPACIM Pvt. Ltd.", date: "06/2023 - 09/2023", location: "Remote", description: "Started the journey in marketing and achieved 100% conversion-to-enquiry rate per post.", planetColor: "#c1440e", planetTexture: "https://www.transparenttextures.com/patterns/sandpaper.png", atmosphereColor: "#e77d11", atmosphereTexture: "https://www.transparenttextures.com/patterns/stardust.png", baseSpeed: "100s", cloudSpeed: "60s", cloudDirection: "reverse", blendMode: "overlay", type: "planet" },
  { order: 2, title: "Finance Intern", company: "Aditya Birla Memorial Hospital", date: "07/2023 - 08/2023", location: "Pune, India", description: "As an intern, I analyzed and processed payroll records for 100+ employees.", planetColor: "#2b65ec", planetTexture: "https://www.transparenttextures.com/patterns/black-scales.png", atmosphereColor: "#10b981", atmosphereTexture: "https://www.transparenttextures.com/patterns/noisy-net.png", baseSpeed: "150s", cloudSpeed: "90s", cloudDirection: "normal", blendMode: "overlay", type: "planet" },
  { order: 3, title: "Financial Modelling Analyst Intern", company: "Financial Dessert Institution", date: "11/2023 - 02/2024", location: "Remote", description: "Built a 5-year DCF model for a retail brand to identify the investment opportunities.", planetColor: "#e6b041", planetTexture: "https://www.transparenttextures.com/patterns/concrete-wall.png", atmosphereColor: "#e68441", atmosphereTexture: "https://www.transparenttextures.com/patterns/dust.png", baseSpeed: "120s", cloudSpeed: "80s", cloudDirection: "reverse", blendMode: "multiply", type: "planet" },
  { order: 4, title: "Accounts, Audit & Finance Executive", company: "DS Chhajed & Asscociates", date: "05/2024 - 08/2024", location: "Pune, India", description: "Managed E2E GST compliance for the corporate and LLP clients with annual turnovers exceeding ₹1.5 crores.", planetColor: "#888888", planetTexture: "https://www.transparenttextures.com/patterns/rocky-wall.png", atmosphereColor: "#555555", atmosphereTexture: "https://www.transparenttextures.com/patterns/stardust.png", baseSpeed: "80s", cloudSpeed: "40s", cloudDirection: "normal", blendMode: "overlay", type: "planet" },
  { order: 5, title: "Asscociate Finance", company: "Addnode India", date: "08/2024 - 04/2026", location: "Pune, India", description: "Managed and generated revenue from 40+ global high-value customers, and developed automated templates for real-time budget tracking.", planetColor: "#ffcc00", planetTexture: "https://www.transparenttextures.com/patterns/noisy-net.png", atmosphereColor: "#ff9900", atmosphereTexture: "https://www.transparenttextures.com/patterns/stardust.png", baseSpeed: "200s", cloudSpeed: "100s", cloudDirection: "reverse", blendMode: "color-burn", type: "planet" }
];
---

<Layout title="Suhas Jawale | My Career Journey" hideNav={true}>
  <ScrollSnapController client:load />
  <JumpHandler client:load />
  <SwipeIndicator client:load />
  
  <Starfield client:load />
  <MeteoriteField client:load />
  <div class="scanline" />

  <div class="relative z-10 w-full overflow-x-hidden">
    <WhoAmI client:load />

    <div class="relative">
      {experiences.map((exp) => (
        <PlanetScene client:load experience={exp} />
      ))}
    </div>

    <section class="h-screen flex items-center justify-center relative z-20 bg-black/90 backdrop-blur-3xl italic">
      <div class="text-center max-w-6xl px-8 w-full italic">
         <div class="inline-block px-8 py-3 bg-primary-finance/10 border border-primary-finance/30 rounded-full mb-12 animate-pulse italic">
            <span class="text-xs md:text-sm font-space tracking-[0.5em] text-primary-finance uppercase italic">Upcoming...</span>
         </div>
         
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 italic text-left">
            <a href="/projects" class="group relative p-10 bg-black/40 backdrop-blur-2xl border border-white/5 hover:border-primary-finance/50 rounded-2xl transition-all hover:shadow-[0_0_50px_rgba(16,185,129,0.1)] block italic">
               <h3 class="text-3xl font-bold font-space text-white mb-4 italic group-hover:text-primary-finance transition-colors">Projects</h3>
               <p class="text-white/40 leading-relaxed italic mb-8">
                  Interactive models to forecast financial health of businesses.
               </p>
               <span class="text-xs font-bold text-primary-finance uppercase tracking-widest flex items-center gap-2 italic">Explore Projects →</span>
            </a>

            <a href="/journal" class="group relative p-10 bg-black/40 backdrop-blur-2xl border border-white/5 hover:border-primary-edu/50 rounded-2xl transition-all hover:shadow-[0_0_50px_rgba(251,146,60,0.1)] block italic">
               <h3 class="text-3xl font-bold font-space text-white mb-4 italic group-hover:text-primary-edu transition-colors">The Journal</h3>
               <p class="text-white/40 leading-relaxed italic mb-8">
                  Uncovering complex thoughts, and breaking them down in simple terms.
               </p>
               <span class="text-xs font-bold text-primary-edu uppercase tracking-widest flex items-center gap-2 italic">Read Entries →</span>
            </a>
         </div>
      </div>
    </section>

    <section class="h-screen flex items-center justify-center relative z-20 bg-black/90 backdrop-blur-3xl italic border-t border-white/5">
      <div class="text-center max-w-6xl px-8 w-full italic">
         <h4 class="text-2xl md:text-4xl font-space tracking-[0.3em] text-white/40 uppercase mb-16 italic">Let's Connect</h4>
         <SocialLinks client:load />
         
         <div class="grid grid-cols-1 md:grid-cols-3 gap-8 opacity-40 italic text-left md:text-center">
            <div class="flex flex-col gap-2 italic">
               <span class="text-[10px] uppercase tracking-widest italic font-bold">Stellar Location</span>
               <span class="text-sm md:text-base font-space italic">Pune / India</span>
            </div>
            <div class="flex flex-col gap-2 italic">
               <span class="text-[10px] uppercase tracking-widest italic font-bold">Vessel Type</span>
               <span class="text-sm md:text-base font-space italic">Portfolio v0.1</span>
            </div>
            <div class="flex flex-col gap-2 italic">
               <span class="text-[10px] uppercase tracking-widest italic font-bold">Pilot</span>
               <span class="text-sm md:text-base font-space italic">Suhas-5j</span>
            </div>
         </div>
      </div>
    </section>

  </div>

  <section class="h-screen flex items-center justify-center relative z-50 bg-black border-t border-white/5">
     <div class="w-full max-w-4xl mx-auto px-8">
        <DeveloperCredit client:load />
     </div>
  </section>

  <CockpitHUD client:load />
</Layout>

<style is:global>
  body { background-color: #000; overflow-x: hidden; cursor: crosshair; }
  .scanline { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03)); background-size: 100% 4px, 3px 100%; pointer-events: none; z-index: 100; opacity: 0.1; }
  html { scroll-behavior: smooth; }
</style>