---
import Layout from '../layouts/Layout.astro';
import { Starfield } from '../components/SpaceJourney/Starfield';
import { MeteoriteField } from '../components/SpaceJourney/MeteoriteField';
import { CockpitHUD } from '../components/SpaceJourney/CockpitHUD';
import { WhoAmI } from '../components/SpaceJourney/WhoAmI';
import { PlanetScene } from '../components/SpaceJourney/PlanetScene';

const experiences = [
  {
    order: 1,
    title: "Financial Foundations",
    company: "Capital Growth Partners",
    date: "2018 - 2020",
    location: "Mumbai",
    description: "Architected complex derivative models for private equity portfolios, achieving 15% efficiency gain in risk reporting.",
    planetColor: "#10b981", // Emerald
    planetTexture: "https://www.transparenttextures.com/patterns/black-mamba.png",
    atmosphereColor: "#10b981",
    atmosphereTexture: "https://www.transparenttextures.com/patterns/stardust.png",
    baseSpeed: "100s",
    cloudSpeed: "60s",
    cloudDirection: "reverse",
    blendMode: "overlay"
  },
  {
    order: 2,
    title: "The Transition",
    company: "EduTech Global",
    date: "2020 - 2022",
    location: "Remote",
    description: "Bridged the gap between high-finance and accessible education by building interactive learning platforms for aspiring traders.",
    planetColor: "#34d399", // Emerald Light
    planetTexture: "https://www.transparenttextures.com/patterns/concrete-wall.png",
    atmosphereColor: "#34d399",
    atmosphereTexture: "https://www.transparenttextures.com/patterns/noisy-net.png",
    baseSpeed: "150s",
    cloudSpeed: "90s",
    cloudDirection: "normal",
    blendMode: "multiply"
  },
  {
    order: 3,
    title: "Modern Educator",
    company: "Self-Employed",
    date: "2022 - 2023",
    location: "Global",
    description: "Guided over 10,000 students on financial literacy and wellness through personalized digital coaching and interactive content.",
    planetColor: "#fb923c", // Orange
    planetTexture: "https://www.transparenttextures.com/patterns/black-scales.png",
    atmosphereColor: "#fb923c",
    atmosphereTexture: "https://www.transparenttextures.com/patterns/dust.png",
    baseSpeed: "120s",
    cloudSpeed: "80s",
    cloudDirection: "reverse",
    blendMode: "overlay"
  },
  {
    order: 4,
    title: "Social Impact Lead",
    company: "HealthFirst Foundation",
    date: "2023 - 2024",
    location: "Global",
    description: "Spearheaded digital campaigns addressing social issues and health awareness, impacting thousands of lives globally.",
    planetColor: "#f87171", // Red
    planetTexture: "https://www.transparenttextures.com/patterns/sandpaper.png",
    atmosphereColor: "#f87171",
    atmosphereTexture: "https://www.transparenttextures.com/patterns/stardust.png",
    baseSpeed: "80s",
    cloudSpeed: "40s",
    cloudDirection: "normal",
    blendMode: "color-burn"
  },
  {
    order: 5,
    title: "The Knowledge Orbit",
    company: "Current Venture",
    date: "2024 - Present",
    location: "Global",
    description: "Building an integrated ecosystem for personal development, combining finance expertise with social and health guidance.",
    planetColor: "#6366f1", // Indigo
    planetTexture: "https://www.transparenttextures.com/patterns/rocky-wall.png",
    atmosphereColor: "#6366f1",
    atmosphereTexture: "https://www.transparenttextures.com/patterns/crissXcross.png",
    baseSpeed: "200s",
    cloudSpeed: "100s",
    cloudDirection: "reverse",
    blendMode: "overlay"
  }
];
---

<Layout title="Knowledge Orbit | Suhas - Interstellar Odyssey">
  <!-- Immersive Background Layers -->
  <Starfield client:load />
  <MeteoriteField client:load />
  <div class="scanline" />

  <!-- The Journey Container -->
  <div class="relative z-10 w-full overflow-x-hidden">
    
    <!-- Intro Phase -->
    <WhoAmI client:load />

    <!-- Space Exploration Phase (Experiences) -->
    <div class="relative">
      {experiences.map((exp) => (
        <PlanetScene client:load experience={exp} />
      ))}
    </div>

    <!-- Final Call to Action -->
    <section class="min-h-screen flex items-center justify-center relative z-20 bg-black/90 backdrop-blur-3xl italic">
      <div class="text-center max-w-6xl px-8 italic">
         <div class="inline-block px-6 py-2 bg-primary-finance/10 border border-primary-finance/30 rounded-full mb-12 animate-pulse italic">
            <span class="text-[10px] font-space tracking-[0.5em] text-primary-finance uppercase italic">Mission Complete</span>
         </div>
         <h2 class="text-6xl md:text-9xl font-bold font-space mb-12 bg-gradient-to-r from-primary-finance to-primary-edu bg-clip-text text-transparent tracking-tighter italic">
           Establish Contact.
         </h2>
         <p class="text-2xl md:text-3xl text-white/40 mb-16 max-w-2xl mx-auto italic leading-relaxed">
           Ready to start a new orbit? Reach out for financial consulting, educational partnerships, or just to say hi.
         </p>
         <div class="flex flex-wrap justify-center gap-8 italic">
            <a href="mailto:contact@knowledgeorbit.com" class="group px-10 py-5 bg-primary-finance text-white font-bold rounded-full transition-all hover:scale-105 hover:bg-emerald-600 shadow-2xl shadow-emerald-500/20 italic">
               Send Encrypted Signal (Email)
            </a>
            <a href="/lab" class="group px-10 py-5 bg-white/5 border border-primary-finance/30 text-primary-finance font-bold rounded-full transition-all hover:scale-105 hover:bg-primary-finance/10 italic">
               Enter Research Lab (Finance Models)
            </a>
            <a href="/journal" class="group px-10 py-5 bg-white/5 border border-white/10 text-white font-bold rounded-full transition-all hover:scale-105 hover:bg-white/10 italic">
               Open System Logs (Journal)
            </a>
         </div>
         
         <div class="mt-32 grid grid-cols-2 md:grid-cols-4 gap-12 opacity-30 italic">
            <div class="flex flex-col gap-2 italic">
               <span class="text-[8px] uppercase tracking-widest italic font-bold">Stellar Location</span>
               <span class="text-xs font-space italic">Sector 7-G / Mumbai</span>
            </div>
            <div class="flex flex-col gap-2 italic">
               <span class="text-[8px] uppercase tracking-widest italic font-bold">Vessel Type</span>
               <span class="text-xs font-space italic">Knowledge Orbit v2.0</span>
            </div>
            <div class="flex flex-col gap-2 italic">
               <span class="text-[8px] uppercase tracking-widest italic font-bold">Pilot</span>
               <span class="text-xs font-space italic">Suhas-5j</span>
            </div>
            <div class="flex flex-col gap-2 italic">
               <span class="text-[8px] uppercase tracking-widest italic font-bold">Status</span>
               <span class="text-xs font-space italic uppercase italic">Awaiting Signal</span>
            </div>
         </div>
      </div>
    </section>

  </div>

  <!-- Space Cockpit HUD (Fixed) -->
  <CockpitHUD client:load />

</Layout>

<style is:global>
  /* Base reset for immersive experience */
  body {
    background-color: #000;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* Custom animations for the environment */
  @keyframes moveLeft {
    from { transform: translateX(0); opacity: 0.5; }
    to { transform: translateX(-100vw); opacity: 0; }
  }

  @keyframes moveRight {
    from { transform: translateX(0); opacity: 0.5; }
    to { transform: translateX(100vw); opacity: 0; }
  }

  /* Text-shadow glow for the HUD */
  .text-glow-emerald {
    text-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
  }

  /* Apple-style smooth scrolling across the entire site */
  html {
    scroll-behavior: smooth;
  }
</style>
