---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "The Knowledge Orbit - A Portfolio Journey through Finance and Education" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-space-bg text-gray-100 min-h-screen font-sans selection:bg-primary-finance/30">
		<header class="fixed top-0 left-0 w-full z-50 bg-space-bg/80 backdrop-blur-md border-b border-space-border">
			<nav class="container mx-auto px-6 py-4 flex justify-between items-center">
				<a href="/" class="text-2xl font-bold font-space bg-gradient-to-r from-primary-finance to-primary-edu bg-clip-text text-transparent">
					Knowledge Orbit
				</a>
				<ul class="hidden md:flex space-x-8 text-sm font-medium">
					<li><a href="#journey" class="hover:text-primary-finance transition-colors uppercase tracking-widest">Journey</a></li>
					<li><a href="#lab" class="hover:text-primary-finance transition-colors uppercase tracking-widest">The Lab</a></li>
					<li><a href="#journal" class="hover:text-primary-edu transition-colors uppercase tracking-widest">The Journal</a></li>
					<li><a href="#contact" class="hover:text-white transition-colors uppercase tracking-widest">Connect</a></li>
				</ul>
				<div class="md:hidden">
					<!-- Mobile menu button -->
					<button id="mobile-menu-btn" class="p-2 text-gray-400 hover:text-white focus:outline-none">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
						</svg>
					</button>
				</div>
			</nav>
		</header>
		<main class="pt-16">
			<slot />
		</main>
		<footer class="bg-space-card py-12 border-t border-space-border">
			<div class="container mx-auto px-6 text-center">
				<p class="text-gray-400 text-sm">
					&copy; {new Date().getFullYear()} Suhas | Built with Astro & Framer Motion
				</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
		--font-space: 'Space Grotesk', sans-serif;
	}
	
	body {
		font-family: var(--font-sans);
	}
	
	.font-space {
		font-family: var(--font-space);
	}
</style>
